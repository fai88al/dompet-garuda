# Copy this file to .env and fill in real values. Never commit .env.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5434/dompet
SPRING_DATASOURCE_USERNAME=dompet
SPRING_DATASOURCE_PASSWORD=

# Used by docker-compose.yml for the postgres container
POSTGRES_PASSWORD=

# Static admin Bearer token — set a strong random value in production environments.
# Protects all /admin/** endpoints. See CLAUDE.md §4.
ADMIN_API_TOKEN=
